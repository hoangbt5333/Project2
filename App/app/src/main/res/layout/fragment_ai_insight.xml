<?xml version="1.0" encoding="utf-8"?>
<!-- Layout cho man hinh AI Insight. Dat tai res/layout/fragment_ai_insight.xml -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phân tích AI"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:paddingBottom="12dp" />

        <!-- Trang thai rong -->
        <TextView
            android:id="@+id/txtEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chưa có dữ liệu AI. Hãy mở màn hình chính để hệ thống phân tích và lưu nhật ký."
            android:textSize="14sp"
            android:textColor="#607D8B"
            android:padding="16dp"
            android:background="#FFFFFF"
            android:visibility="gone" />

        <!-- CARD: Ket qua moi nhat -->
        <LinearLayout
            android:id="@+id/cardLatest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kết quả mới nhất"
                android:textStyle="bold"
                android:textColor="#37474F" />

            <TextView
                android:id="@+id/txtLatestTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textSize="12sp"
                android:textColor="#90A4AE"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Điểm đất"
                    android:textColor="#607D8B" />

                <TextView
                    android:id="@+id/txtLatestScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/100"
                    android:textStyle="bold"
                    android:textColor="#1B5E20" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtLatestDecision"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingBottom="6dp" />

            <TextView
                android:id="@+id/txtLatestSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#37474F"
                android:paddingBottom="6dp" />

            <TextView
                android:id="@+id/txtLatestRecommendation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="#2E7D32"
                android:background="#E8F5E9"
                android:padding="10dp" />
        </LinearLayout>

        <!-- CARD: Viec nen lam -->
        <LinearLayout
            android:id="@+id/cardActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Việc nên làm"
                android:textStyle="bold"
                android:textColor="#37474F"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/txtActionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI sẽ hiển thị các việc nên làm ở đây."
                android:textSize="14sp"
                android:textColor="#2E7D32"
                android:background="#E8F5E9"
                android:padding="10dp"
                android:lineSpacingExtra="3dp" />

        </LinearLayout>

        <!-- CARD: Cay trong phu hop -->
        <LinearLayout
            android:id="@+id/cardCropSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cây trồng phù hợp"
                android:textStyle="bold"
                android:textColor="#37474F"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dựa trên pH, NPK, độ ẩm đất và nhiệt độ hiện tại."
                android:textSize="12sp"
                android:textColor="#78909C"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/txtCropSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cây phù hợp sẽ hiển thị ở đây."
                android:textSize="14sp"
                android:textColor="#1B5E20"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

        <!-- CARD: Cay chua phu hop -->
        <LinearLayout
            android:id="@+id/cardNotRecommendedCrops"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cây chưa nên trồng"
                android:textStyle="bold"
                android:textColor="#37474F"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Các cây có điểm phù hợp thấp hoặc dễ gặp rủi ro với điều kiện đất hiện tại."
                android:textSize="12sp"
                android:textColor="#78909C"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/txtNotRecommendedCrops"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cây chưa phù hợp sẽ hiển thị ở đây."
                android:textSize="14sp"
                android:textColor="#5D4037"
                android:background="#FFF3E0"
                android:padding="10dp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
