<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- MUC 1: Timeline canh bao -->
        <TextView style="@style/HistorySectionTitle" android:text="Lich su canh bao" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAlerts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <!-- MUC 2: Nhat ky AI -->
        <TextView style="@style/HistorySectionTitle" android:text="Nhat ky AI (AI Analysis History)" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAiDaily"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <!-- MUC 3: Thong ke loai canh bao trong tuan -->
        <TextView style="@style/HistorySectionTitle" android:text="So lan canh bao trong tuan" />
        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/chartAlertTypes"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="20dp" />

        <!-- MUC 4: Phan bo trang thai dat 30 ngay -->
        <TextView style="@style/HistorySectionTitle" android:text="Trang thai dat trong 30 ngay" />
        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/chartSoilStatus"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginBottom="20dp" />

        <!-- MUC 5: Lich su tuoi nuoc -->
        <TextView style="@style/HistorySectionTitle" android:text="Lich su tuoi nuoc" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvWatering"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <!-- MUC 6: Bang du lieu lich su -->
        <TextView style="@style/HistorySectionTitle" android:text="Bang du lieu lich su" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="6dp"
            android:paddingHorizontal="12dp"
            android:background="#ECEFF1">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="Time" android:textStyle="bold" android:textSize="13sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Moisture" android:textStyle="bold" android:textSize="13sp" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.3" android:gravity="end" android:text="NPK" android:textStyle="bold" android:textSize="13sp" />
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDataTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp" />

        <!-- MUC 7: Diem suc khoe dat theo ngay -->
        <TextView style="@style/HistorySectionTitle" android:text="Diem suc khoe dat theo ngay (7 ngay)" />
        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/chartHealthScore"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
