<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/tvTemperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nhiệt độ: -- °C"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"/>

    <TextView
        android:id="@+id/tvHumidity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Độ ẩm: -- %"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_margin="20dp"
        android:background="#CCCCCC" />

    <Button
        android:id="@+id/btnToggleBuzzer"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:text="BẬT/TẮT CÒI (Đang tắt)"
        android:backgroundTint="@android:color/holo_green_dark"
        android:layout_marginTop="20dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_margin="20dp"
        android:background="#CCCCCC" />

    <TextView
        android:id="@+id/tvCurrentThreshold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ngưỡng cảnh báo hiện tại: -- °C"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/edtThreshold"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:hint="Nhập ngưỡng mới"
        android:inputType="numberDecimal"
        android:layout_marginTop="10dp"
        android:gravity="center"/>

    <Button
        android:id="@+id/btnUpdateThreshold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cập nhật ngưỡng"
        android:layout_marginTop="5dp"/>

</LinearLayout>